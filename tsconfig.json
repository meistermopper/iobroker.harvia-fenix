{
	"compilerOptions": {
		"target": "ES2019",
		"module": "CommonJS",
		"lib": ["es2019"],
		"outDir": "build",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": true,
		"baseUrl": "./",
		"paths": {
			"*": ["node_modules/*"]
		},
		"types": ["node"]
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules", "src/**/*.test.ts"]
}
