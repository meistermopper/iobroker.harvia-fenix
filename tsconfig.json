{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"lib": ["ES2022"],
		"outDir": "build",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"sourceMap": true,
		"moduleResolution": "NodeNext",
		"types": ["node", "mocha", "chai"] // Add mocha and chai to include test runner types
	},
	"ts-node": {
		"compilerOptions": {
			"module": "NodeNext"
		}
	},
	"include": ["src/**/*.ts", "test/**/*.ts"],
	"exclude": ["node_modules"]
}
