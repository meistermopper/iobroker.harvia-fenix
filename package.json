{
	"name": "iobroker.harvia-fenix",
	"version": "0.0.1",
	"description": "ioBroker adapter for Harvia Fenix Sauna Control",
	"type": "commonjs",
	"author": {
		"name": "Thomas",
		"email": "meister.mopper@gmail.com"
	},
	"homepage": "https://github.com/meistermopper/ioBroker.harvia-fenix",
	"license": "MIT",
	"keywords": [
		"ioBroker",
		"Harvia",
		"Fenix",
		"Sauna"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/meistermopper/iobroker.harvia-fenix.git"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.2.2",
		"axios": "^1.7.9"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@iobroker/testing": "^5.1.0",
		"@tsconfig/node20": "^20.1.4",
		"@types/chai": "^4.3.20",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.17.10",
		"chai": "^4.5.0",
		"mocha": "^10.7.3",
		"rimraf": "^6.1.3",
		"source-map-support": "^0.5.21",
		"ts-node": "^10.9.2",
		"typescript": "~5.7.3",
		"husky": "^9.1.7",
		"lint-staged": "^15.2.11"
	},
	"main": "build/main.js",
	"files": [
		"admin",
		"build",
		"io-package.json",
		"LICENSE"
	],
	"scripts": {
		"test:ts": "node --require ts-node/register node_modules/mocha/bin/mocha --config test/mocharc.build.json",
		"test:package": "mocha test/package --exit",
		"test:unit": "mocha test/unit --exit",
		"test:integration": "mocha test/integration --exit",
		"test": "npm run test:ts && npm run test:package",
		"check": "biome check .",
		"format": "biome format --write .",
		"build": "rimraf build && tsc -p tsconfig.build.json",
		"watch": "tsc -p tsconfig.build.json --watch",
		"lint": "biome check .",
		"release": "npx iobroker release --yes",
		"prepare": "husky"
	},
	"bugs": "https://github.com/meistermopper/ioBroker.harvia-fenix/issues",
	"readmeFilename": "README.md",
	"allowScripts": {
		"@biomejs/biome@2.4.16": true,
		"esbuild@0.25.12": true
	},
	"overrides": {
		"debug": "^4.3.1",
		"diff": "^5.0.1",
		"esbuild": "^0.25.12",
		"glob": "^11.0.0",
		"js-yaml": "^3.14.2",
		"minimatch": "^3.1.4",
		"nanoid": "^3.3.8",
		"serialize-javascript": "^7.0.5"
	},
	"lint-staged": {
		"*.{ts,js,json}": "biome check --write --no-errors-on-unmatched",
		"**/*.{ts,js,json}": "biome check --write --no-errors-on-unmatched"
	}
}
