{
	"name": "iobroker.harvia-fenix",
	"version": "0.0.21",
	"description": "ioBroker adapter for Harvia Fenix Sauna Control",
	"type": "commonjs",
	"author": {
		"name": "meistermopper",
		"email": "meister.mopper@gmail.com"
	},
	"homepage": "https://github.com/meistermopper/ioBroker.harvia-fenix",
	"license": "MIT",
	"keywords": [
		"ioBroker",
		"Harvia",
		"Fenix",
		"Sauna"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/meistermopper/ioBroker.harvia-fenix.git"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.3.2",
		"axios": "^1.7.9"
	},
	"devDependencies": {
		"@alcalzone/release-script": "^5.2.1",
		"@alcalzone/release-script-plugin-changelog": "^5.2.0",
		"@alcalzone/release-script-plugin-git": "^5.2.0",
		"@alcalzone/release-script-plugin-iobroker": "^5.2.0",
		"@alcalzone/release-script-plugin-license": "^5.2.0",
		"@alcalzone/release-script-plugin-manual-review": "^5.2.0",
		"@alcalzone/release-script-plugin-package": "^5.2.0",
		"@alcalzone/release-script-plugin-version": "^5.2.0",
		"@biomejs/biome": "^2.4.16",
		"@iobroker/adapter-dev": "^1.3.0",
		"@iobroker/eslint-config": "^1.0.0",
		"@iobroker/testing": "^5.1.1",
		"@tsconfig/node20": "^20.1.9",
		"@types/chai": "^5.2.3",
		"@types/mocha": "^10.0.10",
		"@types/node": "^20.17.10",
		"chai": "^6.2.2",
		"cross-env": "^10.1.0",
		"mocha": "^11.3.0",
		"source-map-support": "^0.5.21",
		"ts-node": "^10.9.2",
		"typescript": "~6.0.3"
	},
	"main": "build/main.js",
	"files": [
		"admin",
		"build",
		"io-package.json",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"test:ts": "cross-env NODE_OPTIONS=\"--no-experimental-detect-module\" mocha --config test/mocharc.build.json",
		"test:package": "cross-env NODE_OPTIONS=\"--no-experimental-detect-module\" mocha test/package --exit",
		"test:unit": "cross-env NODE_OPTIONS=\"--no-experimental-detect-module\" mocha test/unit --exit || exit 0",
		"test:integration": "cross-env NODE_OPTIONS=\"--no-experimental-detect-module\" mocha test/integration --exit || exit 0",
		"test": "npm run test:ts && npm run test:package",
		"check": "biome check .",
		"format": "biome format --write .",
		"build": "node -e \"require('fs').rmSync('build', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
		"watch": "tsc -p tsconfig.build.json --watch",
		"lint": "biome check .",
		"release": "release-script"
	},
	"bugs": "https://github.com/meistermopper/ioBroker.harvia-fenix/issues",
	"readmeFilename": "README.md",
	"overrides": {
		"glob": "^11.1.0",
		"minimatch": "^10.0.1"
	},
	"publishConfig": {
		"provenance": true
	}
}
