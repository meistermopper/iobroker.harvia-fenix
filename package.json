{
	"name": "iobroker.harvia-fenix",
	"version": "0.0.25",
	"description": "ioBroker adapter for Harvia Fenix Sauna Control",
	"type": "commonjs",
	"author": {
		"name": "meistermopper",
		"email": "meister.mopper@gmail.com"
	},
	"homepage": "https://github.com/meistermopper/ioBroker.harvia-fenix",
	"license": "MIT",
	"keywords": [
		"ioBroker",
		"Harvia",
		"Fenix",
		"Sauna"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/meistermopper/ioBroker.harvia-fenix.git"
	},
	"engines": {
		"node": ">=22"
	},
	"dependencies": {
		"@iobroker/adapter-core": "^3.3.2",
		"axios": "^1.7.9"
	},
	"devDependencies": {
		"@alcalzone/release-script": "^5.2.1",
		"@alcalzone/release-script-plugin-changelog": "^5.2.0",
		"@alcalzone/release-script-plugin-git": "^5.2.0",
		"@alcalzone/release-script-plugin-iobroker": "^5.2.0",
		"@alcalzone/release-script-plugin-license": "^5.2.0",
		"@alcalzone/release-script-plugin-manual-review": "^5.2.0",
		"@alcalzone/release-script-plugin-package": "^5.2.0",
		"@alcalzone/release-script-plugin-version": "^5.2.0",
		"@biomejs/biome": "^2.4.16",
		"@iobroker/adapter-dev": "^1.5.0",
		"@iobroker/testing": "^5.2.2",
		"@tsconfig/node22": "^22.0.0",
		"@types/node": "^22.13.0",
		"cross-env": "^10.1.0",
		"source-map-support": "^0.5.21",
		"ts-node": "^10.9.2",
		"typescript": "~5.7.3"
	},
	"main": "build/main.js",
	"files": [
		"admin",
		"build",
		"io-package.json",
		"LICENSE",
		"README.md"
	],
	"scripts": {
		"test:integration": "cross-env NODE_OPTIONS=\"--no-experimental-detect-module\" mocha test/integration --exit",
		"test:ts": "tsc --noEmit",
		"test:package": "npx -y @iobroker/repochecker https://github.com/meistermopper/ioBroker.harvia-fenix --local",
		"test": "npm run build && npm run test:package && npm run test:integration",
		"check": "biome check .",
		"format": "biome format --write .",
		"build": "npm run format && node -e \"require('fs').rmSync('build', { recursive: true, force: true })\" && tsc -p tsconfig.build.json",
		"watch": "tsc -p tsconfig.build.json --watch",
		"lint": "biome check .",
		"release": "release-script"
	},
	"bugs": "https://github.com/meistermopper/ioBroker.harvia-fenix/issues",
	"readmeFilename": "README.md",
	"overrides": {
		"glob": "11.1.0",
		"minimatch": "10.0.1"
	},
	"publishConfig": {
		"provenance": true
	}
}
